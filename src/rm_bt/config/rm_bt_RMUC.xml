      <PubFloat name="小陀螺转速控制"
                topic_name="rotate_speed"
                float_data="1.0"/>
      <SendGoal name="中央高地巡逻点1"
                goal_pose="7.06;-6.96;0; 0;0;0;1"
                action_name="navigate_to_pose"/>
      <Sleep msec="3000"/>
      <SendGoal name="中央高地巡逻点2"
                goal_pose="11.88;-6.37;0; 0;0;0;1"
                action_name="navigate_to_pose"/>
      <Sleep msec="3000"/>
      <SendGoal name="中央高地巡逻点3"

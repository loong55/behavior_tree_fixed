      <PubFloat name="小陀螺转速控制"
                topic_name="rotate_speed"
                float_data="1.0"/>
      <SendGoal name="中央高地巡逻点1"
                goal_pose="11.88;2.44;0; 0;0;0;1"
                action_name="navigate_to_pose"/>
      <Sleep msec="5000"/>
      <SendGoal name="中央高地巡逻点2"
                goal_pose="10.35;1.97;0; 0;0;0;1"

<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="BehaviorTree">
  <BehaviorTree ID="BehaviorTree">
    <ReactiveSequence>
      <SubTree ID="获取比赛相关信息"
               _autoremap="true"/>
      <WhileDoElse>
        <ISGameStart message="{game_progress_status}"/>
        <WhileDoElse>
          <IfRestoresHpOrPill both_camp_hp="{both_camp_hp}"
                              sentry_blood_threshold="135"
                              sentry_full_blood="400"
                              game_time="{game_time}"
                              projectile_number="{permitted_pill_number}"/>
          <SubTree ID="回血或者补充弹丸"
                   _autoremap="true"/>
          <WhileDoElse>
            <IsTimeBack game_time="{game_time}"
                        set_minutes="5"/>
            <SubTree ID="比赛时间&gt;=设定时间，返回基地"
                     _autoremap="true"/>
            <SubTree ID="比赛时间&lt;设定时间，正常策略"
                     _autoremap="true"/>
          </WhileDoElse>
        </WhileDoElse>
        <Sleep msec="2000"/>
      </WhileDoElse>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="回血或者补充弹丸">
    <Sequence>
      <SubTree ID="获取机器人当前所在区域"
               _autoremap="true"/>
      <Switch3 case_1="1"
               case_2="2"
               case_3="3"
               variable="{current_area}">
        <Sequence name="区域1（己方基地区域）路线">
          <SubTree ID="路线(己方区域-&gt;补给区门口)"
                   _autoremap="true"/>
          <Repeat num_cycles="10000">
            <RetryUntilSuccessful num_attempts="10000">
              <SubTree ID="路线(补给区门口-&gt;补给区域)"
                       _autoremap="true"/>
            </RetryUntilSuccessful>
          </Repeat>
        </Sequence>
        <Sequence name="区域2（中间高地）路线">
          <SubTree ID="路线(中央区域-&gt;补给区门口)"
                   _autoremap="true"/>
          <Repeat num_cycles="10000">
            <RetryUntilSuccessful num_attempts="10000">
              <SubTree ID="路线(补给区门口-&gt;补给区域)"
                       _autoremap="true"/>
            </RetryUntilSuccessful>
          </Repeat>
        </Sequence>
        <Sequence name="区域3（目前不打算去地方区域，默认该区域无用）路线">
          <SubTree ID="路线(default-&gt;补给区门口)"
                   _autoremap="true"/>
          <Repeat num_cycles="10000">
            <RetryUntilSuccessful num_attempts="10000">
              <SubTree ID="路线(补给区门口-&gt;补给区域)"
                       _autoremap="true"/>
            </RetryUntilSuccessful>
          </Repeat>
        </Sequence>
        <Sequence name="区域3（目前不打算去地方区域，默认该区域无用）路线">
          <SubTree ID="路线(default-&gt;补给区门口)"
                   _autoremap="true"/>
          <Repeat num_cycles="10000">
            <RetryUntilSuccessful num_attempts="10000">
              <SubTree ID="路线(补给区门口-&gt;补给区域)"
                       _autoremap="true"/>
            </RetryUntilSuccessful>
          </Repeat>
        </Sequence>
      </Switch3>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="巡逻(中央高地)">

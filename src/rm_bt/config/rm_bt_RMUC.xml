            <Repeat num_cycles="10000">
              <RetryUntilSuccessful num_attempts="10000">
                <SubTree ID="巡逻(己方基地)"
                         _autoremap="true"/>
              </RetryUntilSuccessful>
            </Repeat>
          </Sequence>
          <Sequence name="区域2（中间高地）路线">
            <SubTree ID="路线(中央区域-&gt;己方区域)"
                     _autoremap="true"/>
            <Repeat num_cycles="10000">
              <Repeat num_cycles="10000">
                <SubTree ID="巡逻(己方基地)"
                         _autoremap="true"/>
              </Repeat>
            </Repeat>
          </Sequence>
          <Sequence name="区域3（目前不打算去地方区域，默认该区域无用）路线">
            <SubTree ID="路线(default-&gt;己方区域)"
                     _autoremap="true"/>
            <Repeat num_cycles="10000">
              <Repeat num_cycles="10000">
                <SubTree ID="巡逻(己方基地)"
                         _autoremap="true"/>
              </Repeat>
            </Repeat>
          </Sequence>
          <Sequence name="区域3（目前不打算去地方区域，默认该区域无用）路线">
            <SubTree ID="路线(default-&gt;己方区域)"
                     _autoremap="true"/>
            <Repeat num_cycles="10000">
              <Repeat num_cycles="10000">
                <SubTree ID="巡逻(己方基地)"
                         _autoremap="true"/>
              </Repeat>
            </Repeat>
          </Sequence>
        </Switch3>
      </Sequence>
    </WhileDoElse>
  </BehaviorTree>

  <BehaviorTree ID="获取机器人当前所在区域">
    <RetryUntilSuccessful num_attempts="100000">
      <GetCurrentArea name="区域{1:己方基地区域} {2:中央高地区域} {3:敌人基地区域}"
                      area_1="&quot;{1:0.30,5.91},{2:10.88,5.85},{3:6.70,0.27},{4:6.88,-3.78},{5:6.65,-6.90},{6:0.65,-6.66},{7:0.71,-8.55},{8:-2.82,-5.61}&quot;"
                      area_2="&quot;{1:10.88,5.85},{2:6.70,0.27},{3:6.88,-3.78},{4:6.65,-6.90},{5:0.65,-6.66},{6:0.71,-8.55},{7:10.94,-8.90},{8:14.76,-3.26},{9:14.82,2.15},{10:15.17,4.09},{11:16.87,6.09}&quot;"
                      area_3="&quot;{1:19.46,0.74},{2:23.87,0.80},{3:21.16,-2.84}&quot;"
                      current_area="{current_area}"/>
    </RetryUntilSuccessful>
  </BehaviorTree>

  <BehaviorTree ID="获取比赛相关信息">
    <Sequence>
      <SubGameStatus topic_name="game_progress_status"
                     game_status="{game_progress_status}"/>
      <SubProjectileNumber topic_name="permitted_pill_number"
                           projectile_number="{permitted_pill_number}"/>
      <SubBothCampHp topic_name="both_camp_hp"
                     both_camp_hp="{both_camp_hp}"/>
      <SubDecisionStatus topic_name="game_decision_status"
                         game_decision_status="{game_decision_status}"/>
      <SubGameTime topic_name="game_time"
                   game_time="{game_time}"/>
      <SubIsDetectEnemy topic_name="gimbal_command"
                        detect_enemy_status="{detect_enemy_status}"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="识别到敌人后停下来攻击">
    <Sequence>
      <PubFloat name="小陀螺转速控制"
                topic_name="rotate_speed"
                float_data="1.0"/>
      <PubFloat name="开启2d雷达融合"
                topic_name="if_pub_ms200_scan"
                float_data="1.0"/>
      <RetryUntilSuccessful num_attempts="10000">
        <GetCurrentLocation current_location="{current_location}"/>
      </RetryUntilSuccessful>
      <Repeat num_cycles="10000">
        <RetryUntilSuccessful num_attempts="10000">
          <Sequence>
            <SendGoal goal_pose="{current_location}"
                      action_name="navigate_to_pose"/>
            <Sleep msec="1000"/>
          </Sequence>
        </RetryUntilSuccessful>
      </Repeat>
    </Sequence>
  </BehaviorTree>


  <BehaviorTree ID="比赛时间&lt;设定时间，正常策略">
    <WhileDoElse>
      <IsDetectEnemy message="{detect_enemy_status}"/>
      <SubTree ID="识别到敌人后停下来攻击"
               _autoremap="true"/>
      <WhileDoElse>
        <IfEnemyOutpostDie both_camp_hp="{both_camp_hp}"/>
        <Sequence>
          <SubTree ID="获取机器人当前所在区域"
                   _autoremap="true"/>
          <Switch3 case_1="1"
                   case_2="2"
                   case_3="3"
                   variable="{current_area}">
            <Sequence name="区域1（己方基地区域）路线">
              <SubTree ID="路线(己方区域-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <SubTree ID="巡逻(中央高地)"
                           _autoremap="true"/>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
            <Sequence name="区域2（中央高地区域）路线">
              <SubTree ID="路线(中央区域-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <SubTree ID="巡逻(中央高地)"
                           _autoremap="true"/>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
            <Sequence name="区域3（敌方基地区域，默认哨兵不可能在敌方基地）路线">
              <SubTree ID="路线(defalut-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <Sequence>
                    <SubTree ID="巡逻(中央高地)"
                             _autoremap="true"/>
                  </Sequence>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
            <Sequence name="区域default（default）路线">
              <SubTree ID="路线(defalut-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <Sequence>
                    <SubTree ID="巡逻(中央高地)"
                             _autoremap="true"/>
                  </Sequence>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
          </Switch3>
        </Sequence>
        <Sequence>
          <SubTree ID="获取机器人当前所在区域"
                   _autoremap="true"/>
          <Switch3 case_1="1"
                   case_2="2"
                   case_3="3"
                   variable="{current_area}">
            <Sequence name="区域1（己方基地区域）路线">
              <SubTree ID="路线(己方区域-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <SubTree ID="巡逻(敌方前哨战附近)"
                           _autoremap="true"/>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
            <Sequence name="区域2（中央高地区域）路线">
              <SubTree ID="路线(中央区域-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <SubTree ID="巡逻(敌方前哨战附近)"
                           _autoremap="true"/>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
            <Sequence name="区域3（敌方基地区域，默认哨兵不可能在敌方基地）路线">
              <SubTree ID="路线(defalut-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <SubTree ID="巡逻(敌方前哨战附近)"
                           _autoremap="true"/>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
            <Sequence name="区域default（default）路线">
              <SubTree ID="路线(defalut-&gt;中央区域)"
                       _autoremap="true"/>
              <Repeat num_cycles="10000">
                <RetryUntilSuccessful num_attempts="10000">
                  <SubTree ID="巡逻(敌方前哨战附近)"
                           _autoremap="true"/>
                </RetryUntilSuccessful>
              </Repeat>
            </Sequence>
          </Switch3>
        </Sequence>
      </WhileDoElse>
    </WhileDoElse>
  </BehaviorTree>

  <BehaviorTree ID="比赛时间&gt;=设定时间，返回基地">
